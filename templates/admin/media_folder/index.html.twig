{% extends 'admin/layout.html.twig' %}

{% block title %}Medien-Ordner - VSG Admin{% endblock %}

{% block content %}
    <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-md-between gap-3 mb-4">
        <h1 class="h3 mb-0">Medien-Ordner</h1>
        <div class="d-flex flex-wrap gap-2">
            <a href="{{ path('admin_mediathek_index') }}" class="btn btn-secondary">Zur Mediathek</a>
            <a href="{{ path('admin_media_folder_new') }}" class="btn btn-primary">Neuer Ordner</a>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th scope="col">Name</th>
                        <th scope="col" class="text-nowrap text-md-end">Aktionen</th>
                    </tr>
                </thead>
                <tbody>
                    {% for folder in folders %}
                        <tr>
                            <td>{{ folder.name }}</td>
                            <td class="text-md-end">
                                <div class="d-flex flex-wrap gap-2 justify-content-md-end">
                                    <a href="{{ path('admin_media_folder_edit', {id: folder.id}) }}" class="btn btn-primary btn-sm">Bearbeiten</a>
                                    <form method="post" action="{{ path('admin_media_folder_delete', {id: folder.id}) }}" class="d-inline" onsubmit="return confirm('Ordner wirklich löschen?');">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete_media_folder' ~ folder.id) }}">
                                        <button type="submit" class="btn btn-danger btn-sm" aria-label="Löschen" title="Löschen"><i class="fa-solid fa-trash" aria-hidden="true"></i></button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="2" class="text-center text-muted py-5">Keine Ordner vorhanden.</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}
