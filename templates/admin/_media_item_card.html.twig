{#
  media_item: App\Entity\MediaItem
  title: string (e.g. 'Bild', 'Icon')
#}
{% if media_item %}
<div class="card shadow-sm mb-4">
    <div class="card-header">{{ title|default('Mediendatei') }}</div>
    <div class="card-body">
        <div class="row">
            <div class="col-auto">
                {% if media_item.type.value == 'image' and media_item.thumbnailPath and media_item.mimeType != 'image/svg+xml' %}
                    <img src="{{ media_url.buildThumbnailUrl(media_item) }}"
                         alt="{{ media_item.name }}"
                         class="img-thumbnail"
                         style="max-width: 150px; max-height: 150px;">
                {% elseif media_item.type.value == 'image' and media_item.mimeType == 'image/svg+xml' %}
                    <img src="{{ media_url.buildOriginalUrl(media_item) }}"
                         alt="{{ media_item.name }}"
                         class="img-thumbnail"
                         style="max-width: 150px; max-height: 150px;">
                {% else %}
                    <div class="bg-light rounded d-inline-flex align-items-center justify-content-center"
                         style="width: 150px; height: 150px;">
                        {% if media_item.type.value == 'pdf' %}
                            <i class="fa-solid fa-file-pdf fa-3x text-danger" aria-hidden="true"></i>
                        {% else %}
                            <i class="fa-solid fa-file fa-3x text-secondary" aria-hidden="true"></i>
                        {% endif %}
                    </div>
                {% endif %}
            </div>
            <div class="col">
                <dl class="row mb-0">
                    <dt class="col-sm-4">Name</dt>
                    <dd class="col-sm-8">{{ media_item.name }}</dd>
                    <dt class="col-sm-4">Typ</dt>
                    <dd class="col-sm-8">{% if media_item.type.value == 'image' %}Bild{% else %}PDF{% endif %}</dd>
                    <dt class="col-sm-4">Größe</dt>
                    <dd class="col-sm-8">{{ media_url.formatSizeHuman(media_item.sizeBytes) }}</dd>
                </dl>
                <a href="{{ path('admin_mediathek_item_edit', { id: media_item.id }) }}"
                   class="btn btn-sm btn-outline-primary mt-2"
                   aria-label="Bearbeiten" title="Bearbeiten">
                    <i class="fa-solid fa-pen-to-square" aria-hidden="true"></i>
                </a>
            </div>
        </div>
    </div>
    {% if selector_content is defined and selector_content %}
    <div class="card-footer bg-body-tertiary">
        {{ selector_content|raw }}
    </div>
    {% endif %}
</div>
{% endif %}
