{% extends 'admin/layout.html.twig' %}

{% block title %}{{ user.fullName }} - Benutzerverwaltung - VSG Admin{% endblock %}

{% block content %}
    <div class="main-header">
        <h1>{{ user.fullName }}</h1>
        <div class="actions">
            <a href="{{ path('admin_user_edit', {id: user.id}) }}" class="btn btn-primary">Bearbeiten</a>
            <a href="{{ path('admin_user_index') }}" class="btn btn-secondary">Zurück</a>
        </div>
    </div>

    <div class="card">
        <dl class="detail-grid">
            <dt>ID</dt>
            <dd>{{ user.id }}</dd>

            <dt>E-Mail</dt>
            <dd>{{ user.email }}</dd>

            <dt>Vorname</dt>
            <dd>{{ user.firstName }}</dd>

            <dt>Nachname</dt>
            <dd>{{ user.lastName }}</dd>

            <dt>Rollen</dt>
            <dd>
                {% for role in user.roles %}
                    <span class="badge {{ role == 'ROLE_ADMIN' ? 'badge-primary' : 'badge-success' }}">{{ role }}</span>
                {% endfor %}
            </dd>
        </dl>
    </div>

    <div class="card">
        <h3 style="margin-bottom: 1rem; color: #dc3545;">Benutzer löschen</h3>
        <form method="post" action="{{ path('admin_user_delete', {id: user.id}) }}" onsubmit="return confirm('Sind Sie sicher, dass Sie diesen Benutzer löschen möchten?');">
            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ user.id) }}">
            <button type="submit" class="btn btn-danger">Benutzer löschen</button>
        </form>
    </div>
{% endblock %}
