{% extends 'admin/layout.html.twig' %}

{% block title %}Benutzerverwaltung - VSG Admin{% endblock %}

{% block content %}
    <div class="main-header">
        <h1>Benutzerverwaltung</h1>
        <a href="{{ path('admin_user_new') }}" class="btn btn-primary">Neuer Benutzer</a>
    </div>

    <div class="card" style="padding: 0; overflow: hidden;">
        <table>
            <thead>
                <tr>
                    <th>Name</th>
                    <th>E-Mail</th>
                    <th>Rollen</th>
                    <th style="width: 180px;">Aktionen</th>
                </tr>
            </thead>
            <tbody>
                {% for user in users %}
                    <tr>
                        <td>{{ user.fullName }}</td>
                        <td>{{ user.email }}</td>
                        <td>
                            {% for role in user.roles %}
                                <span class="badge {{ role == 'ROLE_ADMIN' ? 'badge-primary' : 'badge-success' }}">{{ role }}</span>
                            {% endfor %}
                        </td>
                        <td>
                            <div class="actions">
                                <a href="{{ path('admin_user_show', {id: user.id}) }}" class="btn btn-secondary btn-sm">Anzeigen</a>
                                <a href="{{ path('admin_user_edit', {id: user.id}) }}" class="btn btn-primary btn-sm">Bearbeiten</a>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="4" style="text-align: center; padding: 2rem; color: #999;">Keine Benutzer vorhanden.</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
{% endblock %}
