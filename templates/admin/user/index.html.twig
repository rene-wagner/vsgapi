{% extends 'admin/layout.html.twig' %}

{% block title %}Benutzerverwaltung - VSG Admin{% endblock %}

{% block content %}
    <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-md-between gap-3 mb-4">
        <h1 class="h3 mb-0">Benutzerverwaltung</h1>
        <a href="{{ path('admin_user_new') }}" class="btn btn-primary">Neuer Benutzer</a>
    </div>

    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th scope="col">Name</th>
                        <th scope="col">E-Mail</th>
                        <th scope="col">Rollen</th>
                        <th scope="col" class="text-nowrap text-md-end">Aktionen</th>
                    </tr>
                </thead>
                <tbody>
                    {% for user in users %}
                        <tr>
                            <td>{{ user.fullName }}</td>
                            <td>{{ user.email }}</td>
                            <td>
                                {% for role in user.roles %}
                                    <span class="badge text-bg-{{ role == 'ROLE_ADMIN' ? 'primary' : 'success' }}">{{ role }}</span>
                                {% endfor %}
                            </td>
                            <td class="text-md-end">
                                <div class="d-flex flex-wrap gap-2 justify-content-md-end">
                                    <a href="{{ path('admin_user_show', {id: user.id}) }}" class="btn btn-secondary btn-sm" aria-label="Anzeigen" title="Anzeigen"><i class="fa-solid fa-eye" aria-hidden="true"></i></a>
                                    <a href="{{ path('admin_user_edit', {id: user.id}) }}" class="btn btn-primary btn-sm" aria-label="Bearbeiten" title="Bearbeiten"><i class="fa-solid fa-pen-to-square" aria-hidden="true"></i></a>
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="4" class="text-center text-muted py-5">Keine Benutzer vorhanden.</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}
