{% extends 'admin/layout.html.twig' %}

{% block title %}Sportstätten - VSG Admin{% endblock %}

{% block content %}
    <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-md-between gap-3 mb-4">
        <h1 class="h3 mb-0">Sportstätten</h1>
        <a href="{{ path('admin_location_new') }}" class="btn btn-primary">Neue Sportstätte</a>
    </div>

    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th scope="col">Name</th>
                        <th scope="col">Straße</th>
                        <th scope="col">Stadt</th>
                        <th scope="col" class="text-nowrap text-md-end">Aktionen</th>
                    </tr>
                </thead>
                <tbody>
                    {% for location in locations %}
                        <tr>
                            <td>{{ location.name }}</td>
                            <td>{{ location.street }}</td>
                            <td>{{ location.city }}</td>
                            <td class="text-md-end">
                                <div class="d-flex flex-wrap gap-2 justify-content-md-end">
                                    <a href="{{ path('admin_location_show', {id: location.id}) }}" class="btn btn-secondary btn-sm" aria-label="Anzeigen" title="Anzeigen"><i class="fa-solid fa-eye" aria-hidden="true"></i></a>
                                    <a href="{{ path('admin_location_edit', {id: location.id}) }}" class="btn btn-primary btn-sm" aria-label="Bearbeiten" title="Bearbeiten"><i class="fa-solid fa-pen-to-square" aria-hidden="true"></i></a>
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="4" class="text-center text-muted py-5">Keine Sportstätten vorhanden.</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}
