{% extends 'admin/layout.html.twig' %}

{% block title %}{{ location.name }} - Sportstätten - VSG Admin{% endblock %}

{% block content %}
    <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-md-between gap-3 mb-4">
        <h1 class="h3 mb-0">{{ location.name }}</h1>
        <div class="d-flex flex-wrap gap-2">
            <a href="{{ path('admin_location_edit', {id: location.id}) }}" class="btn btn-primary">Bearbeiten</a>
            <a href="{{ path('admin_location_index') }}" class="btn btn-secondary">Zurück</a>
        </div>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-3 text-secondary small text-uppercase">ID</dt>
                <dd class="col-sm-9">{{ location.id }}</dd>

                <dt class="col-sm-3 text-secondary small text-uppercase">Name</dt>
                <dd class="col-sm-9">{{ location.name }}</dd>

                <dt class="col-sm-3 text-secondary small text-uppercase">Straße</dt>
                <dd class="col-sm-9">{{ location.street }}</dd>

                <dt class="col-sm-3 text-secondary small text-uppercase">Stadt</dt>
                <dd class="col-sm-9">{{ location.city }}</dd>

                <dt class="col-sm-3 text-secondary small text-uppercase">Karten-Link</dt>
                <dd class="col-sm-9">
                    {% if location.mapsUrl %}
                        <a href="{{ location.mapsUrl }}" target="_blank" rel="noopener noreferrer">{{ location.mapsUrl }}</a>
                    {% else %}
                        <span class="text-muted">—</span>
                    {% endif %}
                </dd>
            </dl>
        </div>
    </div>

    <div class="card shadow-sm border-danger">
        <h5 class="card-header text-danger">Sportstätte löschen</h5>
        <div class="card-body">
            <form method="post" action="{{ path('admin_location_delete', {id: location.id}) }}" onsubmit="return confirm('Sind Sie sicher, dass Sie diese Sportstätte löschen möchten?');">
                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ location.id) }}">
                <button type="submit" class="btn btn-danger">Sportstätte löschen</button>
            </form>
        </div>
    </div>
{% endblock %}
