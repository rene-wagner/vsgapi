{{ form_start(form, { attr: { class: 'department-form', novalidate: 'novalidate' } }) }}
    {{ form_errors(form) }}

    <div class="mb-3">
        {{ form_label(form.name) }}
        {{ form_widget(form.name) }}
        {{ form_errors(form.name) }}
    </div>

    <div class="mb-3">
        {{ form_label(form.slug) }}
        {{ form_widget(form.slug) }}
        {{ form_help(form.slug) }}
        {{ form_errors(form.slug) }}
    </div>

    <div class="mb-3">
        {{ form_label(form.description) }}
        {{ form_widget(form.description) }}
        {{ form_errors(form.description) }}
    </div>

    <h3 class="h6 fw-semibold mt-4 mb-2">{{ form_label(form.departmentStats) }}</h3>
    {{ form_errors(form.departmentStats) }}
    <div
        class="collection-holder department-stats-collection"
        data-prototype="{{ form_widget(form.departmentStats.vars.prototype)|e('html_attr') }}"
        data-index="{{ form.departmentStats|length }}"
    >
        {% for stat in form.departmentStats %}
            <div class="collection-item card mb-3 p-3">
                <div class="mb-3">
                    {{ form_label(stat.label) }}
                    {{ form_widget(stat.label) }}
                    {{ form_errors(stat.label) }}
                </div>
                <div class="mb-3">
                    {{ form_label(stat.value) }}
                    {{ form_widget(stat.value) }}
                    {{ form_errors(stat.value) }}
                </div>
                <button type="button" class="btn btn-secondary btn-sm js-remove-collection-item">Eintrag entfernen</button>
            </div>
        {% endfor %}
    </div>
    <p class="mb-4">
        <button type="button" class="btn btn-secondary js-add-stat">Statistik hinzufügen</button>
    </p>

    <h3 class="h6 fw-semibold mb-2">{{ form_label(form.trainingGroups) }}</h3>
    {{ form_errors(form.trainingGroups) }}
    <div
        class="collection-holder department-training-groups-collection"
        data-prototype="{{ form_widget(form.trainingGroups.vars.prototype)|e('html_attr') }}"
        data-index="{{ form.trainingGroups|length }}"
    >
        {% for group in form.trainingGroups %}
            <div class="collection-item card mb-4 p-3">
                <div class="mb-3">
                    {{ form_label(group.name) }}
                    {{ form_widget(group.name) }}
                    {{ form_help(group.name) }}
                    {{ form_errors(group.name) }}
                </div>
                <div class="mb-3">
                    {{ form_label(group.ageRange) }}
                    {{ form_widget(group.ageRange) }}
                    {{ form_help(group.ageRange) }}
                    {{ form_errors(group.ageRange) }}
                </div>
                <h4 class="h6 fw-semibold mt-3 mb-2">{{ form_label(group.departmentTrainingSessions) }}</h4>
                {{ form_errors(group.departmentTrainingSessions) }}
                <div
                    class="collection-holder department-training-sessions-collection"
                    data-prototype="{{ form_widget(group.departmentTrainingSessions.vars.prototype)|e('html_attr') }}"
                    data-index="{{ group.departmentTrainingSessions|length }}"
                >
                    {% for session in group.departmentTrainingSessions %}
                        <div class="collection-item card mb-3 p-3 bg-body-secondary">
                            <div class="mb-3">
                                {{ form_label(session.day) }}
                                {{ form_widget(session.day) }}
                                {{ form_help(session.day) }}
                                {{ form_errors(session.day) }}
                            </div>
                            <div class="mb-3">
                                {{ form_label(session.time) }}
                                {{ form_widget(session.time) }}
                                {{ form_help(session.time) }}
                                {{ form_errors(session.time) }}
                            </div>
                            <div class="mb-3 checkbox-list">
                                {{ form_label(session.locations) }}
                                {{ form_widget(session.locations) }}
                                {{ form_errors(session.locations) }}
                            </div>
                            <button type="button" class="btn btn-secondary btn-sm js-remove-session">Trainingseinheit entfernen</button>
                        </div>
                    {% endfor %}
                </div>
                <p class="mb-2">
                    <button type="button" class="btn btn-secondary btn-sm js-add-session">Trainingseinheit hinzufügen</button>
                </p>
                <button type="button" class="btn btn-secondary btn-sm js-remove-group">Trainingsgruppe entfernen</button>
            </div>
        {% endfor %}
    </div>
    <p class="mb-4">
        <button type="button" class="btn btn-secondary js-add-group">Trainingsgruppe hinzufügen</button>
    </p>

    <button type="submit" class="btn btn-primary">Speichern</button>
{{ form_end(form) }}

<script>
(function () {
    function bindRemoveStat(btn) {
        btn.addEventListener('click', function () {
            btn.closest('.collection-item').remove();
        });
    }

    function bindRemoveGroup(btn) {
        btn.addEventListener('click', function () {
            btn.closest('.collection-item').remove();
        });
    }

    function bindRemoveSession(btn) {
        btn.addEventListener('click', function () {
            btn.closest('.collection-item').remove();
        });
    }

    function bindAddSession(btn) {
        btn.addEventListener('click', function () {
            var groupCard = btn.closest('.collection-item');
            var holder = groupCard.querySelector('.department-training-sessions-collection');
            var proto = holder.dataset.prototype;
            var sidx = parseInt(holder.dataset.index, 10);
            var div = document.createElement('div');
            div.className = 'collection-item card mb-3 p-3 bg-body-secondary';
            div.innerHTML = proto.replace(/__session__/g, String(sidx)) +
                '<button type="button" class="btn btn-secondary btn-sm js-remove-session">Trainingseinheit entfernen</button>';
            holder.appendChild(div);
            holder.dataset.index = String(sidx + 1);
            bindRemoveSession(div.querySelector('.js-remove-session'));
        });
    }

    document.querySelectorAll('.js-add-stat').forEach(function (btn) {
        btn.addEventListener('click', function () {
            var holder = document.querySelector('.department-stats-collection');
            var proto = holder.dataset.prototype;
            var idx = parseInt(holder.dataset.index, 10);
            var div = document.createElement('div');
            div.className = 'collection-item card mb-3 p-3';
            div.innerHTML = proto.replace(/__stat__/g, String(idx)) +
                '<button type="button" class="btn btn-secondary btn-sm js-remove-collection-item">Eintrag entfernen</button>';
            holder.appendChild(div);
            holder.dataset.index = String(idx + 1);
            bindRemoveStat(div.querySelector('.js-remove-collection-item'));
        });
    });

    document.querySelectorAll('.department-stats-collection .js-remove-collection-item').forEach(bindRemoveStat);

    document.querySelectorAll('.js-add-group').forEach(function (btn) {
        btn.addEventListener('click', function () {
            var holder = document.querySelector('.department-training-groups-collection');
            var proto = holder.dataset.prototype;
            var idx = parseInt(holder.dataset.index, 10);
            var html = proto
                .replace(/__session__/g, '0')
                .replace(/__group__/g, String(idx));
            var div = document.createElement('div');
            div.className = 'collection-item card mb-4 p-3';
            div.innerHTML = html +
                '<p class="mb-2"><button type="button" class="btn btn-secondary btn-sm js-add-session">Trainingseinheit hinzufügen</button></p>' +
                '<button type="button" class="btn btn-secondary btn-sm js-remove-group">Trainingsgruppe entfernen</button>';
            holder.appendChild(div);
            holder.dataset.index = String(idx + 1);
            var sessionsHolder = div.querySelector('.department-training-sessions-collection');
            if (sessionsHolder) {
                sessionsHolder.dataset.index = String(div.querySelectorAll('.department-training-sessions-collection > .collection-item').length);
            }
            bindAddSession(div.querySelector('.js-add-session'));
            bindRemoveGroup(div.querySelector('.js-remove-group'));
        });
    });

    document.querySelectorAll('.js-add-session').forEach(bindAddSession);

    document.querySelectorAll('.js-remove-group').forEach(bindRemoveGroup);

    document.querySelectorAll('.js-remove-session').forEach(bindRemoveSession);
})();
</script>
