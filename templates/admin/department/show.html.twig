{% extends 'admin/layout.html.twig' %}

{% block title %}{{ department.name }} - VSG Admin{% endblock %}

{% block content %}
    <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-md-between gap-3 mb-4">
        <h1 class="h3 mb-0">{{ department.name }}</h1>
        <div class="d-flex flex-wrap gap-2">
            <a href="{{ path('admin_department_edit', {id: department.id}) }}" class="btn btn-primary">Bearbeiten</a>
            <a href="{{ path('admin_department_index') }}" class="btn btn-secondary">Zurück</a>
        </div>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-3 text-secondary small text-uppercase">ID</dt>
                <dd class="col-sm-9">{{ department.id }}</dd>

                <dt class="col-sm-3 text-secondary small text-uppercase">Name</dt>
                <dd class="col-sm-9">{{ department.name }}</dd>

                <dt class="col-sm-3 text-secondary small text-uppercase">Slug</dt>
                <dd class="col-sm-9"><code>{{ department.slug }}</code></dd>

                <dt class="col-sm-3 text-secondary small text-uppercase">Beschreibung</dt>
                <dd class="col-sm-9 admin-pre-content mb-0">{{ department.description }}</dd>
            </dl>
        </div>
    </div>

    {% if department.departmentStats|length > 0 %}
        <div class="card shadow-sm mb-4">
            <h5 class="card-header">Statistiken</h5>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-sm table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th scope="col">Bezeichnung</th>
                                <th scope="col">Wert</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for stat in department.departmentStats %}
                                <tr>
                                    <td>{{ stat.label }}</td>
                                    <td>{{ stat.value }}</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    {% endif %}

    {% if department.trainingGroups|length > 0 %}
        {% for group in department.trainingGroups %}
            <div class="card shadow-sm mb-4">
                <h5 class="card-header">{{ group.name }}</h5>
                <div class="card-body">
                    {% if group.ageRange %}
                        <p class="text-secondary mb-3">Altersgruppe: {{ group.ageRange }}</p>
                    {% endif %}

                    {% if group.departmentTrainingSessions|length > 0 %}
                        <div class="table-responsive">
                            <table class="table table-sm table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th scope="col">Tag</th>
                                        <th scope="col">Zeit</th>
                                        <th scope="col">Sportstätten</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for session in group.departmentTrainingSessions %}
                                        <tr>
                                            <td>{{ session.day }}</td>
                                            <td>{{ session.time }}</td>
                                            <td>
                                                {% if session.locations|length > 0 %}
                                                    {% for loc in session.locations %}
                                                        {{ loc.name }}{% if not loop.last %}, {% endif %}
                                                    {% endfor %}
                                                {% else %}
                                                    <span class="text-muted">—</span>
                                                {% endif %}
                                            </td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    {% else %}
                        <p class="text-muted mb-0">Keine Trainingseinheiten eingetragen.</p>
                    {% endif %}
                </div>
            </div>
        {% endfor %}
    {% endif %}

    {% if department.icon %}
        {% include 'admin/_media_item_card.html.twig' with { media_item: department.icon, title: 'Icon' } %}
    {% endif %}

    <div class="card shadow-sm border-danger">
        <h5 class="card-header text-danger">Abteilung löschen</h5>
        <div class="card-body">
            <form method="post" action="{{ path('admin_department_delete', {id: department.id}) }}" onsubmit="return confirm('Sind Sie sicher, dass Sie diese Abteilung löschen möchten?');">
                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ department.id) }}">
                <button type="submit" class="btn btn-danger">Abteilung löschen</button>
            </form>
        </div>
    </div>
{% endblock %}
