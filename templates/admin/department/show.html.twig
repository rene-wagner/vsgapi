{% extends 'admin/layout.html.twig' %}

{% block title %}{{ department.name }} - VSG Admin{% endblock %}

{% block content %}
    <div class="main-header">
        <h1>{{ department.name }}</h1>
        <div class="actions">
            <a href="{{ path('admin_department_edit', {id: department.id}) }}" class="btn btn-primary">Bearbeiten</a>
            <a href="{{ path('admin_department_index') }}" class="btn btn-secondary">Zurück</a>
        </div>
    </div>

    <div class="card">
        <dl class="detail-grid">
            <dt>ID</dt>
            <dd>{{ department.id }}</dd>

            <dt>Name</dt>
            <dd>{{ department.name }}</dd>

            <dt>Slug</dt>
            <dd><code>{{ department.slug }}</code></dd>

            <dt>Beschreibung</dt>
            <dd style="white-space: pre-wrap;">{{ department.description }}</dd>
        </dl>
    </div>

    {% if department.departmentStats|length > 0 %}
        <div class="card">
            <h3 style="margin-bottom: 1rem;">Statistiken</h3>
            <table>
                <thead>
                    <tr>
                        <th>Bezeichnung</th>
                        <th>Wert</th>
                    </tr>
                </thead>
                <tbody>
                    {% for stat in department.departmentStats %}
                        <tr>
                            <td>{{ stat.label }}</td>
                            <td>{{ stat.value }}</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}

    {% if department.trainingGroups|length > 0 %}
        {% for group in department.trainingGroups %}
            <div class="card">
                <h3 style="margin-bottom: 0.5rem;">{{ group.name }}</h3>
                <p style="color: #666; margin-bottom: 1rem;">Altersgruppe: {{ group.ageRange }}</p>

                {% if group.departmentTrainingSessions|length > 0 %}
                    <table>
                        <thead>
                            <tr>
                                <th>Tag</th>
                                <th>Zeit</th>
                                <th>Sportstätten</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for session in group.departmentTrainingSessions %}
                                <tr>
                                    <td>{{ session.day }}</td>
                                    <td>{{ session.time }}</td>
                                    <td>
                                        {% if session.locations|length > 0 %}
                                            {% for loc in session.locations %}
                                                {{ loc.name }}{% if not loop.last %}, {% endif %}
                                            {% endfor %}
                                        {% else %}
                                            <span style="color: #999;">—</span>
                                        {% endif %}
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                {% else %}
                    <p style="color: #999;">Keine Trainingseinheiten eingetragen.</p>
                {% endif %}
            </div>
        {% endfor %}
    {% endif %}

    <div class="card">
        <h3 style="margin-bottom: 1rem; color: #dc3545;">Abteilung löschen</h3>
        <form method="post" action="{{ path('admin_department_delete', {id: department.id}) }}" onsubmit="return confirm('Sind Sie sicher, dass Sie diese Abteilung löschen möchten?');">
            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ department.id) }}">
            <button type="submit" class="btn btn-danger">Abteilung löschen</button>
        </form>
    </div>
{% endblock %}
