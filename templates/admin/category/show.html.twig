{% extends 'admin/layout.html.twig' %}

{% block title %}{{ category.name }} - Kategorien - VSG Admin{% endblock %}

{% block content %}
    <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-md-between gap-3 mb-4">
        <h1 class="h3 mb-0">{{ category.name }}</h1>
        <div class="d-flex flex-wrap gap-2">
            <a href="{{ path('admin_category_edit', {id: category.id}) }}" class="btn btn-primary">Bearbeiten</a>
            <a href="{{ path('admin_category_index') }}" class="btn btn-secondary">Zurück</a>
        </div>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-3 text-secondary small text-uppercase">ID</dt>
                <dd class="col-sm-9">{{ category.id }}</dd>

                <dt class="col-sm-3 text-secondary small text-uppercase">Name</dt>
                <dd class="col-sm-9">{{ category.name }}</dd>

                <dt class="col-sm-3 text-secondary small text-uppercase">Slug</dt>
                <dd class="col-sm-9"><span class="badge text-bg-secondary">{{ category.slug }}</span></dd>
            </dl>
        </div>
    </div>

    <div class="card shadow-sm border-danger">
        <h5 class="card-header text-danger">Kategorie löschen</h5>
        <div class="card-body">
            <form method="post" action="{{ path('admin_category_delete', {id: category.id}) }}" onsubmit="return confirm('Sind Sie sicher, dass Sie diese Kategorie löschen möchten?');">
                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ category.id) }}">
                <button type="submit" class="btn btn-danger">Kategorie löschen</button>
            </form>
        </div>
    </div>
{% endblock %}
