{% extends 'admin/layout.html.twig' %}

{% block title %}Kontaktpersonen - VSG Admin{% endblock %}

{% block content %}
    <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-md-between gap-3 mb-4">
        <h1 class="h3 mb-0">Kontaktpersonen</h1>
        <a href="{{ path('admin_contact_person_new') }}" class="btn btn-primary">Neue Kontaktperson</a>
    </div>

    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th scope="col">Name</th>
                        <th scope="col">Funktion</th>
                        <th scope="col">Slug</th>
                        <th scope="col">E-Mail</th>
                        <th scope="col" class="text-nowrap text-md-end">Aktionen</th>
                    </tr>
                </thead>
                <tbody>
                    {% for contact_person in contactPeople %}
                        <tr>
                            <td>{{ contact_person.lastName }}, {{ contact_person.firstName }}</td>
                            <td>
                                {% if contact_person.position %}
                                    {{ contact_person.position }}
                                {% else %}
                                    <span class="text-muted">—</span>
                                {% endif %}
                            </td>
                            <td>{{ contact_person.slug }}</td>
                            <td>
                                {% if contact_person.email %}
                                    {{ contact_person.email }}
                                {% else %}
                                    <span class="text-muted">—</span>
                                {% endif %}
                            </td>
                            <td class="text-md-end">
                                <div class="d-flex flex-wrap gap-2 justify-content-md-end">
                                    <a href="{{ path('admin_contact_person_show', {id: contact_person.id}) }}" class="btn btn-secondary btn-sm" aria-label="Anzeigen" title="Anzeigen"><i class="fa-solid fa-eye" aria-hidden="true"></i></a>
                                    <a href="{{ path('admin_contact_person_edit', {id: contact_person.id}) }}" class="btn btn-primary btn-sm" aria-label="Bearbeiten" title="Bearbeiten"><i class="fa-solid fa-pen-to-square" aria-hidden="true"></i></a>
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="5" class="text-center text-muted py-5">Keine Kontaktpersonen vorhanden.</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}
