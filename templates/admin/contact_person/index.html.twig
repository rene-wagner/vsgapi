{% extends 'admin/layout.html.twig' %}

{% block title %}Kontaktpersonen - VSG Admin{% endblock %}

{% block content %}
    <div class="main-header">
        <h1>Kontaktpersonen</h1>
        <a href="{{ path('admin_contact_person_new') }}" class="btn btn-primary">Neue Kontaktperson</a>
    </div>

    <div class="card" style="padding: 0; overflow: hidden;">
        <table>
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Slug</th>
                    <th>E-Mail</th>
                    <th style="width: 180px;">Aktionen</th>
                </tr>
            </thead>
            <tbody>
                {% for contact_person in contactPeople %}
                    <tr>
                        <td>{{ contact_person.lastName }}, {{ contact_person.firstName }}</td>
                        <td>{{ contact_person.slug }}</td>
                        <td>{{ contact_person.email ?? '—' }}</td>
                        <td>
                            <div class="actions">
                                <a href="{{ path('admin_contact_person_show', {id: contact_person.id}) }}" class="btn btn-secondary btn-sm">Anzeigen</a>
                                <a href="{{ path('admin_contact_person_edit', {id: contact_person.id}) }}" class="btn btn-primary btn-sm">Bearbeiten</a>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="4" style="text-align: center; padding: 2rem; color: #999;">Keine Kontaktpersonen vorhanden.</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
{% endblock %}
