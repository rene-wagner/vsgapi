{% extends 'admin/layout.html.twig' %}

{% block title %}{{ contact_person.firstName }} {{ contact_person.lastName }} - VSG Admin{% endblock %}

{% block content %}
    <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-md-between gap-3 mb-4">
        <h1 class="h3 mb-0">{{ contact_person.firstName }} {{ contact_person.lastName }}</h1>
        <div class="d-flex flex-wrap gap-2">
            <a href="{{ path('admin_contact_person_edit', {id: contact_person.id}) }}" class="btn btn-primary">Bearbeiten</a>
            <a href="{{ path('admin_contact_person_index') }}" class="btn btn-secondary">Zurück</a>
        </div>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-3 text-secondary small text-uppercase">ID</dt>
                <dd class="col-sm-9">{{ contact_person.id }}</dd>

                <dt class="col-sm-3 text-secondary small text-uppercase">Slug</dt>
                <dd class="col-sm-9">{{ contact_person.slug }}</dd>

                <dt class="col-sm-3 text-secondary small text-uppercase">Vorname</dt>
                <dd class="col-sm-9">{{ contact_person.firstName }}</dd>

                <dt class="col-sm-3 text-secondary small text-uppercase">Nachname</dt>
                <dd class="col-sm-9">{{ contact_person.lastName }}</dd>

                <dt class="col-sm-3 text-secondary small text-uppercase">E-Mail</dt>
                <dd class="col-sm-9">
                    {% if contact_person.email %}
                        <a href="mailto:{{ contact_person.email }}">{{ contact_person.email }}</a>
                    {% else %}
                        <span class="text-muted">—</span>
                    {% endif %}
                </dd>

                <dt class="col-sm-3 text-secondary small text-uppercase">Telefon</dt>
                <dd class="col-sm-9">
                    {% if contact_person.phone %}
                        {{ contact_person.phone }}
                    {% else %}
                        <span class="text-muted">—</span>
                    {% endif %}
                </dd>

                <dt class="col-sm-3 text-secondary small text-uppercase">Adresse</dt>
                <dd class="col-sm-9">
                    {% if contact_person.address %}
                        {{ contact_person.address|nl2br }}
                    {% else %}
                        <span class="text-muted">—</span>
                    {% endif %}
                </dd>
            </dl>
        </div>
    </div>

    <div class="card shadow-sm border-danger">
        <div class="card-body">
            <h2 class="h5 text-danger mb-3">Kontaktperson löschen</h2>
            <form method="post" action="{{ path('admin_contact_person_delete', {id: contact_person.id}) }}" onsubmit="return confirm('Sind Sie sicher, dass Sie diese Kontaktperson löschen möchten?');">
                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ contact_person.id) }}">
                <button type="submit" class="btn btn-danger">Kontaktperson löschen</button>
            </form>
        </div>
    </div>
{% endblock %}
