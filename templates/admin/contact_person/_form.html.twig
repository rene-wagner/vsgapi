{{ form_start(form) }}
    <div class="mb-3">
        {{ form_label(form.slug) }}
        {{ form_widget(form.slug) }}
        {{ form_help(form.slug) }}
        {{ form_errors(form.slug) }}
    </div>

    <div class="mb-3">
        {{ form_label(form.firstName) }}
        {{ form_widget(form.firstName) }}
        {{ form_errors(form.firstName) }}
    </div>

    <div class="mb-3">
        {{ form_label(form.lastName) }}
        {{ form_widget(form.lastName) }}
        {{ form_errors(form.lastName) }}
    </div>

    <div class="mb-3">
        {{ form_label(form.position) }}
        {{ form_widget(form.position) }}
        {{ form_errors(form.position) }}
    </div>

    <div class="mb-3">
        {{ form_label(form.email) }}
        {{ form_widget(form.email) }}
        {{ form_errors(form.email) }}
    </div>

    <div class="mb-3">
        {{ form_label(form.phone) }}
        {{ form_widget(form.phone) }}
        {{ form_errors(form.phone) }}
    </div>

    <div class="mb-3">
        {{ form_label(form.address) }}
        {{ form_widget(form.address, { attr: { 'data-controller': 'easymde' } }) }}
        {{ form_errors(form.address) }}
    </div>

    <div class="mb-3">
        {{ form_label(form.isBoard) }}
        {{ form_widget(form.isBoard) }}
        {{ form_errors(form.isBoard) }}
    </div>

    {% if contact_person.picture %}
        {# Selector IN die Card verschieben #}
        <div class="mb-3" data-media-selector data-controller="media-selector-wrappers">
            {{ include('admin/_media_item_card.html.twig', {
                media_item: contact_person.picture,
                media_url: media_url,
                title: 'Aktuelles Bild'|trans,
                selector_content: '
                    <div class="mb-0">
                        <label class="form-label">' ~ 'Bild auswählen'|trans ~ '</label>
                        <div class="d-flex gap-2">
                            <button type="button" class="btn btn-sm btn-outline-primary" data-action="click->media-selector-wrappers#open">
                                <i class="fa-solid fa-image" aria-hidden="true"></i> ' ~ 'Auswählen'|trans ~ '
                            </button>
                            <button type="button" class="btn btn-sm btn-outline-danger" data-media-selector-remove data-action="click->media-selector-wrappers#remove">
                                <i class="fa-solid fa-trash" aria-hidden="true"></i> ' ~ 'Entfernen'|trans ~ '
                            </button>
                        </div>
                    </div>
                '
            }) }}
            {{ form_widget(form.picture) }}
        </div>
    {% else %}
        {# Kein Bild: Selector separat wie bisher #}
        <div class="mb-3" data-media-selector data-controller="media-selector-wrappers">
            <label class="form-label">Bild</label>
            <div data-media-selector-preview></div>
            {{ form_widget(form.picture) }}
            <div class="d-flex gap-2 mt-2">
                <button type="button" class="btn btn-sm btn-outline-primary" data-action="click->media-selector-wrappers#open">
                    <i class="fa-solid fa-image" aria-hidden="true"></i> {{ 'Auswählen'|trans }}
                </button>
                <button type="button" class="btn btn-sm btn-outline-danger" data-media-selector-remove data-action="click->media-selector-wrappers#remove" disabled>
                    <i class="fa-solid fa-trash" aria-hidden="true"></i> {{ 'Entfernen'|trans }}
                </button>
            </div>
        </div>
    {% endif %}

    <button type="submit" class="btn btn-primary">Speichern</button>
{{ form_end(form) }}
