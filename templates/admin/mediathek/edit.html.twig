{% extends 'admin/layout.html.twig' %}

{% block title %}Medien bearbeiten - VSG Admin{% endblock %}

{% block content %}
    <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-md-between gap-3 mb-4">
        <h1 class="h3 mb-0">Medien bearbeiten</h1>
        <a href="{% if item.folder %}{{ path('admin_mediathek_index', {folder: item.folder.id}) }}{% else %}{{ path('admin_mediathek_index') }}{% endif %}" class="btn btn-secondary">Zurück</a>
    </div>

    {% set file_url = media_url.buildOriginalUrl(item) %}
    {% set is_image = item.type.value == 'image' %}
    {% set is_croppable = is_image and item.mimeType in ['image/jpeg', 'image/png', 'image/webp'] %}

    {{ form_start(form) }}
    {{ form_errors(form) }}

    <div class="row g-4">
        <div class="col-12 col-lg-5">
            <div class="card shadow-sm h-100">
                <h5 class="card-header fw-semibold">Aktuelles Medium</h5>
                <div class="card-body">
                    {% if is_image %}
                        <div class="text-center mb-3">
                            <img src="{{ file_url }}" alt="{{ item.name|e('html_attr') }}" class="admin-media-edit-preview rounded border">
                        </div>
                        <p class="small text-muted mb-0 text-break">{{ item.name }} · {{ media_url.formatSizeHuman(item.sizeBytes) }}</p>
                    {% else %}
                        <div class="text-center text-danger mb-3" aria-hidden="true">
                            <i class="fa-solid fa-file-pdf fa-3x"></i>
                        </div>
                        <p class="fw-semibold text-break mb-1">{{ item.originalFilename }}</p>
                        <p class="small text-muted mb-2">{{ media_url.formatSizeHuman(item.sizeBytes) }}</p>
                        <p class="small text-muted mb-0">Für PDF-Dateien wird keine Vorschau angezeigt.</p>
                    {% endif %}
                </div>
            </div>
        </div>
        <div class="col-12 col-lg-7">
            <div class="card shadow-sm">
                <div class="card-body">
                    <div class="mb-3">
                        {{ form_label(form.name) }}
                        {{ form_widget(form.name) }}
                        {{ form_errors(form.name) }}
                    </div>
                    <div class="mb-3">
                        {{ form_label(form.description) }}
                        {{ form_widget(form.description, { attr: { 'data-controller': 'easymde' } }) }}
                        {{ form_errors(form.description) }}
                    </div>
                    <div class="mb-3">
                        {{ form_label(form.category) }}
                        {{ form_widget(form.category) }}
                        {{ form_errors(form.category) }}
                    </div>
                    <div class="mb-3">
                        {{ form_label(form.folder) }}
                        {{ form_widget(form.folder) }}
                        {{ form_errors(form.folder) }}
                    </div>

                    {% if not is_croppable %}
                        <div class="d-none">
                            {{ form_widget(form.cropX) }}
                            {{ form_widget(form.cropY) }}
                            {{ form_widget(form.cropWidth) }}
                            {{ form_widget(form.cropHeight) }}
                        </div>
                    {% endif %}

                    <div class="d-flex flex-wrap gap-2 mb-2">
                        <button type="submit" class="btn btn-primary">Speichern</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {% if is_croppable %}
    <div class="row g-4 mt-0">
        <div class="col-12">
            <div class="card shadow-sm"
                 data-controller="image-cropper"
                 data-image-cropper-initial-x-value="{{ form.cropX.vars.value|default('0') }}"
                 data-image-cropper-initial-y-value="{{ form.cropY.vars.value|default('0') }}"
                 data-image-cropper-initial-width-value="{{ form.cropWidth.vars.value|default('0') }}"
                 data-image-cropper-initial-height-value="{{ form.cropHeight.vars.value|default('0') }}">
                <h5 class="card-header fw-semibold">Bildeditor</h5>
                <div class="card-body">
                    <div class="admin-cropper-container mb-3">
                        <img src="{{ file_url }}" alt="{{ item.name|e('html_attr') }}" data-image-cropper-target="image" style="max-width: 100%; display: block;">
                    </div>

                    <div class="row g-3 align-items-end">
                        <div class="col-6 col-md-3">
                            <label class="form-label" for="{{ form.cropX.vars.id }}">X</label>
                            {{ form_widget(form.cropX, { attr: { 'data-image-cropper-target': 'cropX', 'data-action': 'input->image-cropper#syncCropperFromFields', 'class': 'form-control form-control-sm' } }) }}
                            {{ form_errors(form.cropX) }}
                        </div>
                        <div class="col-6 col-md-3">
                            <label class="form-label" for="{{ form.cropY.vars.id }}">Y</label>
                            {{ form_widget(form.cropY, { attr: { 'data-image-cropper-target': 'cropY', 'data-action': 'input->image-cropper#syncCropperFromFields', 'class': 'form-control form-control-sm' } }) }}
                            {{ form_errors(form.cropY) }}
                        </div>
                        <div class="col-6 col-md-3">
                            <label class="form-label" for="{{ form.cropWidth.vars.id }}">Breite</label>
                            {{ form_widget(form.cropWidth, { attr: { 'data-image-cropper-target': 'cropWidth', 'data-action': 'input->image-cropper#syncCropperFromFields', 'class': 'form-control form-control-sm' } }) }}
                            {{ form_errors(form.cropWidth) }}
                        </div>
                        <div class="col-6 col-md-3">
                            <label class="form-label" for="{{ form.cropHeight.vars.id }}">Höhe</label>
                            {{ form_widget(form.cropHeight, { attr: { 'data-image-cropper-target': 'cropHeight', 'data-action': 'input->image-cropper#syncCropperFromFields', 'class': 'form-control form-control-sm' } }) }}
                            {{ form_errors(form.cropHeight) }}
                        </div>
                    </div>

                    <div class="mt-2">
                        <button type="button" class="btn btn-sm btn-outline-secondary" data-action="image-cropper#resetCrop">
                            <i class="fa-solid fa-rotate-left" aria-hidden="true"></i> Zurücksetzen
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
    {% endif %}

    {{ form_widget(form._token) }}
    {{ form_end(form, { render_rest: false }) }}
{% endblock %}
