{% extends 'admin/layout.html.twig' %}

{% block title %}Mediathek - VSG Admin{% endblock %}

{% block content %}
    <div class="main-header">
        <h1>Mediathek</h1>
        <div class="actions">
            <a href="{{ path('admin_media_folder_index') }}" class="btn btn-secondary">Ordner verwalten</a>
            <a href="{{ path('admin_media_folder_new') }}" class="btn btn-primary">Neuer Ordner</a>
        </div>
    </div>

    <div class="card" style="margin-bottom: 1rem;">
        <p class="form-label-like">Ordner</p>
        <div class="form-row-inline">
            <a href="{{ path('admin_mediathek_index') }}" class="btn btn-sm {{ current_folder is null ? 'btn-primary' : 'btn-secondary' }}">Root</a>
            {% for row in folder_tree %}
                <a href="{{ path('admin_mediathek_index', {folder: row.folder.id}) }}" class="btn btn-sm {{ current_folder and current_folder.id == row.folder.id ? 'btn-primary' : 'btn-secondary' }}">{{ row.label }}</a>
            {% endfor %}
        </div>
    </div>

    <div class="card" style="margin-bottom: 1.5rem;">
        <h2 style="font-size: 1.1rem; margin-bottom: 1rem;">Datei hochladen</h2>
        {{ form_start(upload_form, {attr: {enctype: 'multipart/form-data'}}) }}
            <div class="form-group">
                {{ form_label(upload_form.file) }}
                {{ form_widget(upload_form.file) }}
                {{ form_errors(upload_form.file) }}
            </div>
            <div class="form-group">
                {{ form_label(upload_form.folder) }}
                {{ form_widget(upload_form.folder) }}
                {{ form_errors(upload_form.folder) }}
            </div>
            <div class="form-group">
                {{ form_label(upload_form.category) }}
                {{ form_widget(upload_form.category) }}
                {{ form_errors(upload_form.category) }}
            </div>
            <div class="form-group">
                {{ form_label(upload_form.description) }}
                {{ form_widget(upload_form.description) }}
                {{ form_errors(upload_form.description) }}
            </div>
            <div class="form-group">
                {{ form_label(upload_form.name) }}
                {{ form_widget(upload_form.name) }}
                {{ form_errors(upload_form.name) }}
            </div>
            <button type="submit" class="btn btn-primary">Hochladen</button>
        {{ form_end(upload_form) }}
    </div>

    <div class="card" style="padding: 0; overflow: hidden;">
        <table>
            <thead>
                <tr>
                    <th style="width: 90px;">Vorschau</th>
                    <th>Name</th>
                    <th>Typ</th>
                    <th>Größe</th>
                    <th>URL</th>
                    <th style="width: 280px;">Aktionen</th>
                </tr>
            </thead>
            <tbody>
                {% for item in items %}
                    {% set file_url = media_url.buildFileUrl(item.path) %}
                    {% set thumb_url = item.thumbnailPath ? media_url.buildThumbnailUrl(item.thumbnailPath) : null %}
                    <tr>
                        <td>
                            {% if item.type.value == 'image' %}
                                <img src="{{ thumb_url ?? file_url }}" alt="" style="max-width: 72px; max-height: 72px; object-fit: cover; border-radius: 4px;">
                            {% else %}
                                <span class="badge badge-secondary" style="display: inline-block; padding: 1.5rem 0.5rem;">PDF</span>
                            {% endif %}
                        </td>
                        <td>{{ item.name }}</td>
                        <td><span class="badge badge-primary">{{ item.type.value }}</span></td>
                        <td>{{ media_url.formatSizeHuman(item.sizeBytes) }}</td>
                        <td>
                            <input type="text" readonly value="{{ file_url }}" id="media-url-{{ item.id }}" style="width: 100%; max-width: 220px; font-size: 0.75rem; padding: 0.25rem;">
                            <button type="button" class="btn btn-sm btn-secondary" data-copy-target="media-url-{{ item.id }}">Kopieren</button>
                        </td>
                        <td>
                            <div class="actions" style="flex-wrap: wrap;">
                                <a href="{{ path('admin_mediathek_item_edit', {id: item.id}) }}" class="btn btn-primary btn-sm">Bearbeiten</a>
                                <form method="post" action="{{ path('admin_mediathek_item_copy', {id: item.id}) }}" style="display: inline-flex; gap: 0.25rem; align-items: center;">
                                    <input type="hidden" name="_token" value="{{ csrf_token('copy_media_item' ~ item.id) }}">
                                    <select name="folder_id" style="margin: 0; width: auto; max-width: 140px; font-size: 0.8rem; padding: 0.25rem;">
                                        <option value="">Ordner (wie Original)</option>
                                        {% for row in folder_tree %}
                                            <option value="{{ row.folder.id }}">{{ row.label }}</option>
                                        {% endfor %}
                                    </select>
                                    <button type="submit" class="btn btn-secondary btn-sm">Kopieren</button>
                                </form>
                                <form method="post" action="{{ path('admin_mediathek_item_delete', {id: item.id}) }}" onsubmit="return confirm('Wirklich löschen?');" style="display: inline;">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete_media_item' ~ item.id) }}">
                                    <button type="submit" class="btn btn-danger btn-sm">Löschen</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="6" style="text-align: center; padding: 2rem; color: #999;">Keine Medien in diesem Ordner.</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    <script>
        document.querySelectorAll('[data-copy-target]').forEach(function (btn) {
            btn.addEventListener('click', function () {
                var id = btn.getAttribute('data-copy-target');
                var el = document.getElementById(id);
                if (!el) return;
                el.select();
                el.setSelectionRange(0, 99999);
                navigator.clipboard.writeText(el.value).catch(function () {});
            });
        });
    </script>
{% endblock %}
