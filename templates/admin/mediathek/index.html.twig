{% extends 'admin/layout.html.twig' %}

{% block title %}Mediathek - VSG Admin{% endblock %}

{% block content %}
    <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-md-between gap-3 mb-4">
        <h1 class="h3 mb-0">Mediathek</h1>
        <div class="d-flex flex-wrap gap-2">
            <a href="{{ path('admin_media_folder_index') }}" class="btn btn-secondary">Ordner verwalten</a>
            <a href="{{ path('admin_media_folder_new') }}" class="btn btn-primary">Neuer Ordner</a>
        </div>
    </div>

    <div class="card shadow-sm mb-3">
        <div class="card-body">
            <p class="form-label mb-2">Ordner</p>
            <div class="d-flex align-items-center gap-2 flex-wrap">
                <a href="{{ path('admin_mediathek_index') }}" class="btn btn-sm {{ current_folder is null ? 'btn-primary' : 'btn-outline-secondary' }}">Root</a>
                {% for row in folder_tree %}
                    <a href="{{ path('admin_mediathek_index', {folder: row.folder.id}) }}" class="btn btn-sm {{ current_folder and current_folder.id == row.folder.id ? 'btn-primary' : 'btn-outline-secondary' }}">{{ row.label }}</a>
                {% endfor %}
            </div>
        </div>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <h2 class="h5 mb-3">Datei hochladen</h2>
            {{ form_start(upload_form, {attr: {enctype: 'multipart/form-data'}}) }}
                <div class="mb-3">
                    {{ form_label(upload_form.file) }}
                    {{ form_widget(upload_form.file) }}
                    {{ form_errors(upload_form.file) }}
                </div>
                <div class="mb-3">
                    {{ form_label(upload_form.folder) }}
                    {{ form_widget(upload_form.folder) }}
                    {{ form_errors(upload_form.folder) }}
                </div>
                <div class="mb-3">
                    {{ form_label(upload_form.category) }}
                    {{ form_widget(upload_form.category) }}
                    {{ form_errors(upload_form.category) }}
                </div>
                <div class="mb-3">
                    {{ form_label(upload_form.description) }}
                    {{ form_widget(upload_form.description) }}
                    {{ form_errors(upload_form.description) }}
                </div>
                <div class="mb-3">
                    {{ form_label(upload_form.name) }}
                    {{ form_widget(upload_form.name) }}
                    {{ form_errors(upload_form.name) }}
                </div>
                <button type="submit" class="btn btn-primary">Hochladen</button>
            {{ form_end(upload_form) }}
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th scope="col" class="text-nowrap">Vorschau</th>
                        <th scope="col">Name</th>
                        <th scope="col">Typ</th>
                        <th scope="col">Größe</th>
                        <th scope="col">URL</th>
                        <th scope="col" class="text-nowrap text-md-end">Aktionen</th>
                    </tr>
                </thead>
                <tbody>
                    {% for item in items %}
                        {% set file_url = media_url.buildFileUrl(item.path) %}
                        {% set thumb_url = item.thumbnailPath ? media_url.buildThumbnailUrl(item.thumbnailPath) : null %}
                        <tr>
                            <td>
                                {% if item.type.value == 'image' %}
                                    <img src="{{ thumb_url ?? file_url }}" alt="" class="admin-media-thumb rounded">
                                {% else %}
                                    <span class="badge text-bg-secondary d-inline-flex align-items-center px-3 py-4">PDF</span>
                                {% endif %}
                            </td>
                            <td>{{ item.name }}</td>
                            <td><span class="badge text-bg-primary">{{ item.type.value }}</span></td>
                            <td>{{ media_url.formatSizeHuman(item.sizeBytes) }}</td>
                            <td>
                                <div class="d-flex flex-column flex-sm-row align-items-stretch align-items-sm-center gap-2">
                                    <input type="text" readonly value="{{ file_url }}" id="media-url-{{ item.id }}" class="form-control form-control-sm admin-media-url-field">
                                    <button type="button" class="btn btn-sm btn-secondary text-nowrap" data-copy-target="media-url-{{ item.id }}">Kopieren</button>
                                </div>
                            </td>
                            <td class="text-md-end">
                                <div class="d-flex flex-wrap gap-2 justify-content-md-end align-items-center">
                                    <a href="{{ path('admin_mediathek_item_edit', {id: item.id}) }}" class="btn btn-primary btn-sm">Bearbeiten</a>
                                    <form method="post" action="{{ path('admin_mediathek_item_copy', {id: item.id}) }}" class="d-flex flex-wrap align-items-center gap-1 gap-sm-2">
                                        <input type="hidden" name="_token" value="{{ csrf_token('copy_media_item' ~ item.id) }}">
                                        <select name="folder_id" class="form-select form-select-sm admin-copy-folder-select">
                                            <option value="">Ordner (wie Original)</option>
                                            {% for row in folder_tree %}
                                                <option value="{{ row.folder.id }}">{{ row.label }}</option>
                                            {% endfor %}
                                        </select>
                                        <button type="submit" class="btn btn-secondary btn-sm">Kopieren</button>
                                    </form>
                                    <form method="post" action="{{ path('admin_mediathek_item_delete', {id: item.id}) }}" class="d-inline" onsubmit="return confirm('Wirklich löschen?');">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete_media_item' ~ item.id) }}">
                                        <button type="submit" class="btn btn-danger btn-sm">Löschen</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="6" class="text-center text-muted py-5">Keine Medien in diesem Ordner.</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}
