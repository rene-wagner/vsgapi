{% extends 'admin/layout.html.twig' %}

{% block title %}Mediathek - VSG Admin{% endblock %}

{% block content %}
    <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-md-between gap-3 mb-4">
        <h1 class="h3 mb-0">Mediathek</h1>
        <div class="d-flex flex-wrap gap-2">
            <a href="{{ path('admin_media_folder_index') }}" class="btn btn-secondary">Ordner verwalten</a>
            <a href="{{ path('admin_media_folder_new') }}" class="btn btn-primary">Neuer Ordner</a>
        </div>
    </div>

    <div class="card shadow-sm mb-3">
        <div class="card-body pb-0">
            <nav aria-label="Ordnerpfad">
                <ol class="breadcrumb mb-0">
                    {% if current_folder %}
                        <li class="breadcrumb-item"><a href="{{ path('admin_mediathek_index') }}">Mediathek</a></li>
                        {% for f in folder_breadcrumb %}
                            {% if loop.last %}
                                <li class="breadcrumb-item active" aria-current="page">{{ f.name }}</li>
                            {% else %}
                                <li class="breadcrumb-item"><a href="{{ path('admin_mediathek_index', {folder: f.id}) }}">{{ f.name }}</a></li>
                            {% endif %}
                        {% endfor %}
                    {% else %}
                        <li class="breadcrumb-item active" aria-current="page">Mediathek</li>
                    {% endif %}
                </ol>
            </nav>
        </div>
        {% if folders_at_level is empty and items is empty %}
            <div class="card-body pt-3 text-muted text-center py-5 border-top">Keine Ordner oder Dateien in dieser Ebene.</div>
        {% else %}
            <div class="list-group list-group-flush border-top rounded-0">
                {% for subfolder in folders_at_level %}
                    <a href="{{ path('admin_mediathek_index', {folder: subfolder.id}) }}" class="admin-mediathek-row list-group-item list-group-item-action d-flex flex-column flex-sm-row align-items-sm-center gap-3 py-3 px-3 text-decoration-none">
                        <div class="d-flex align-items-center gap-3 flex-grow-1 min-w-0">
                            <span class="d-inline-flex align-items-center justify-content-center rounded bg-body-secondary flex-shrink-0 admin-mediathek-folder-icon" aria-hidden="true">
                                <i class="fa-solid fa-folder text-warning"></i>
                            </span>
                            <div class="min-w-0">
                                <div class="fw-semibold text-body text-truncate">{{ subfolder.name }}</div>
                                <div class="small text-muted">Ordner</div>
                            </div>
                        </div>
                        <div class="text-muted small flex-shrink-0 d-none d-sm-block">
                            <i class="fa-solid fa-chevron-right" aria-hidden="true"></i>
                        </div>
                    </a>
                {% endfor %}
                {% for item in items %}
                    {% set file_url = media_url.buildFileUrl(item.path) %}
                    {% set thumb_url = item.thumbnailPath ? media_url.buildThumbnailUrl(item.thumbnailPath) : null %}
                    <div class="list-group-item border-start-0 border-end-0 px-0 py-0">
                        <div class="admin-mediathek-row d-flex flex-column flex-md-row gap-3 px-3 py-3 border-bottom align-items-md-start">
                            <div class="d-flex gap-3 flex-grow-1 min-w-0">
                                <div class="flex-shrink-0">
                                    {% if item.type.value == 'image' %}
                                        <img src="{{ thumb_url ?? file_url }}" alt="" class="admin-media-thumb rounded">
                                    {% else %}
                                        <span class="badge text-bg-secondary d-inline-flex align-items-center justify-content-center admin-mediathek-pdf-badge">PDF</span>
                                    {% endif %}
                                </div>
                                <div class="min-w-0 flex-grow-1">
                                    <div class="fw-semibold text-break">{{ item.name }}</div>
                                    <div class="small text-muted">{{ item.type.value }} · {{ media_url.formatSizeHuman(item.sizeBytes) }}</div>
                                </div>
                            </div>
                            <div class="admin-mediathek-row-actions d-flex flex-wrap gap-2 flex-shrink-0 align-items-start">
                                <a href="{{ path('admin_mediathek_item_edit', {id: item.id}) }}" class="btn btn-primary btn-sm">Bearbeiten</a>
                                <form method="post" action="{{ path('admin_mediathek_item_delete', {id: item.id}) }}" class="d-inline" onsubmit="return confirm('Wirklich löschen?');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete_media_item' ~ item.id) }}">
                                    <button type="submit" class="btn btn-danger btn-sm">Löschen</button>
                                </form>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% endif %}
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <h2 class="h5 mb-3">Datei hochladen</h2>
            {{ form_start(upload_form, {attr: {enctype: 'multipart/form-data'}}) }}
                <div class="mb-3">
                    {{ form_label(upload_form.file) }}
                    {{ form_widget(upload_form.file) }}
                    {{ form_errors(upload_form.file) }}
                </div>
                <div class="mb-3">
                    {{ form_label(upload_form.folder) }}
                    {{ form_widget(upload_form.folder) }}
                    {{ form_errors(upload_form.folder) }}
                </div>
                <div class="mb-3">
                    {{ form_label(upload_form.category) }}
                    {{ form_widget(upload_form.category) }}
                    {{ form_errors(upload_form.category) }}
                </div>
                <div class="mb-3">
                    {{ form_label(upload_form.description) }}
                    {{ form_widget(upload_form.description) }}
                    {{ form_errors(upload_form.description) }}
                </div>
                <div class="mb-3">
                    {{ form_label(upload_form.name) }}
                    {{ form_widget(upload_form.name) }}
                    {{ form_errors(upload_form.name) }}
                </div>
                <button type="submit" class="btn btn-primary">Hochladen</button>
            {{ form_end(upload_form) }}
        </div>
    </div>
{% endblock %}
