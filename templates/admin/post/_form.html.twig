{{ form_start(form) }}
    <div class="mb-3">
        {{ form_label(form.title) }}
        {{ form_widget(form.title) }}
        {{ form_errors(form.title) }}
    </div>

    <div class="mb-3">
        {{ form_label(form.slug) }}
        {{ form_widget(form.slug) }}
        {{ form_errors(form.slug) }}
        {% if form.slug.vars.help %}
            <div class="form-text">{{ form.slug.vars.help }}</div>
        {% endif %}
    </div>

    <div class="mb-3">
        {{ form_label(form.content) }}
        {{ form_widget(form.content, { attr: { 'data-controller': 'easymde' } }) }}
        {{ form_errors(form.content) }}
    </div>

    <div class="mb-3 d-flex align-items-center gap-2 flex-wrap">
        {{ form_widget(form.published) }}
        {{ form_label(form.published) }}
        {{ form_errors(form.published) }}
    </div>

    <div class="mb-3">
        {{ form_label(form.hits) }}
        {{ form_widget(form.hits) }}
        {{ form_errors(form.hits) }}
        {% if form.hits.vars.help %}
            <div class="form-text">{{ form.hits.vars.help }}</div>
        {% endif %}
    </div>

    <div class="mb-3 d-flex align-items-center gap-2 flex-wrap">
        {{ form_widget(form.oldPost) }}
        {{ form_label(form.oldPost) }}
        {{ form_errors(form.oldPost) }}
    </div>

    <div class="mb-3">
        {{ form_label(form.author) }}
        {{ form_widget(form.author) }}
        {{ form_errors(form.author) }}
    </div>

    <div class="mb-3">
        <span class="form-label d-block">{{ form.categories.vars.label }}</span>
        <div class="checkbox-list">
            {{ form_widget(form.categories) }}
        </div>
        {{ form_errors(form.categories) }}
    </div>

    {% if post.picture %}
        {# Selector IN die Card verschieben #}
        <div class="mb-3" data-media-selector data-controller="media-selector-wrappers">
            {{ include('admin/_media_item_card.html.twig', {
                media_item: post.picture,
                media_url: media_url,
                title: 'Aktuelles Bild'|trans,
                selector_content: '
                    <div class="mb-0">
                        <label class="form-label">' ~ 'Bild auswählen'|trans ~ '</label>
                        <div class="d-flex gap-2">
                            <button type="button" class="btn btn-sm btn-outline-primary" data-action="click->media-selector-wrappers#open">
                                <i class="fa-solid fa-image" aria-hidden="true"></i> ' ~ 'Auswählen'|trans ~ '
                            </button>
                            <button type="button" class="btn btn-sm btn-outline-danger" data-media-selector-remove data-action="click->media-selector-wrappers#remove">
                                <i class="fa-solid fa-trash" aria-hidden="true"></i> ' ~ 'Entfernen'|trans ~ '
                            </button>
                        </div>
                    </div>
                '
            }) }}
            {{ form_widget(form.picture) }}
        </div>
    {% else %}
        {# Kein Bild: Selector separat wie bisher #}
        <div class="mb-3" data-media-selector data-controller="media-selector-wrappers">
            <label class="form-label">Bild</label>
            <div data-media-selector-preview></div>
            {{ form_widget(form.picture) }}
            <div class="d-flex gap-2 mt-2">
                <button type="button" class="btn btn-sm btn-outline-primary" data-action="click->media-selector-wrappers#open">
                    <i class="fa-solid fa-image" aria-hidden="true"></i> {{ 'Auswählen'|trans }}
                </button>
                <button type="button" class="btn btn-sm btn-outline-danger" data-media-selector-remove data-action="click->media-selector-wrappers#remove" disabled>
                    <i class="fa-solid fa-trash" aria-hidden="true"></i> {{ 'Entfernen'|trans }}
                </button>
            </div>
        </div>
    {% endif %}

    <button type="submit" class="btn btn-primary">Speichern</button>
{{ form_end(form) }}
