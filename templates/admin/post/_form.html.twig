{{ form_start(form) }}
    <div class="mb-3">
        {{ form_label(form.title) }}
        {{ form_widget(form.title) }}
        {{ form_errors(form.title) }}
    </div>

    <div class="mb-3">
        {{ form_label(form.slug) }}
        {{ form_widget(form.slug) }}
        {{ form_errors(form.slug) }}
        {% if form.slug.vars.help %}
            <div class="form-text">{{ form.slug.vars.help }}</div>
        {% endif %}
    </div>

    <div class="mb-3">
        {{ form_label(form.content) }}
        {{ form_widget(form.content) }}
        {{ form_errors(form.content) }}
    </div>

    <div class="mb-3 d-flex align-items-center gap-2 flex-wrap">
        {{ form_widget(form.published) }}
        {{ form_label(form.published) }}
        {{ form_errors(form.published) }}
    </div>

    <div class="mb-3">
        {{ form_label(form.hits) }}
        {{ form_widget(form.hits) }}
        {{ form_errors(form.hits) }}
        {% if form.hits.vars.help %}
            <div class="form-text">{{ form.hits.vars.help }}</div>
        {% endif %}
    </div>

    <div class="mb-3 d-flex align-items-center gap-2 flex-wrap">
        {{ form_widget(form.oldPost) }}
        {{ form_label(form.oldPost) }}
        {{ form_errors(form.oldPost) }}
    </div>

    <div class="mb-3">
        {{ form_label(form.author) }}
        {{ form_widget(form.author) }}
        {{ form_errors(form.author) }}
    </div>

    <div class="mb-3">
        <span class="form-label d-block">{{ form.categories.vars.label }}</span>
        <div class="checkbox-list">
            {{ form_widget(form.categories) }}
        </div>
        {{ form_errors(form.categories) }}
    </div>

    {# Aktuelles Bild anzeigen #}
    {% if post.picture %}
        <div class="mb-3">
            {{ include('admin/_media_item_card.html.twig', {
                media_item: post.picture,
                media_url: media_url,
                title: 'Aktuelles Bild'
            }) }}
        </div>
    {% endif %}

    <div class="mb-3" data-media-selector>
        {{ form_label(form.picture) }}
        <div class="admin-media-selector-preview" data-media-selector-preview>
            {% if form.picture.vars.value %}
                <span class="text-truncate">Bild ausgewählt (ID: {{ form.picture.vars.value }})</span>
            {% else %}
                <span class="text-muted">Kein Bild ausgewählt</span>
            {% endif %}
        </div>
        {{ form_widget(form.picture) }}
        {{ form_errors(form.picture) }}
        <button type="button" class="btn btn-secondary btn-sm mt-1" data-media-selector-open>
            <i class="fa-solid fa-image" aria-hidden="true"></i> Auswählen
        </button>
        <button type="button" class="btn btn-outline-secondary btn-sm mt-1 ms-1" data-media-selector-remove {% if not form.picture.vars.value %}disabled{% endif %}>
            <i class="fa-solid fa-xmark" aria-hidden="true"></i> Entfernen
        </button>
    </div>

    <button type="submit" class="btn btn-primary">Speichern</button>
{{ form_end(form) }}
