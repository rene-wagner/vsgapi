{% extends 'admin/layout.html.twig' %}

{% block title %}Beiträge - VSG Admin{% endblock %}

{% block content %}
    <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-md-between gap-3 mb-4">
        <h1 class="h3 mb-0">Beiträge</h1>
        <a href="{{ path('admin_post_new') }}" class="btn btn-primary">Neuer Beitrag</a>
    </div>

    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th scope="col">Titel</th>
                        <th scope="col">Slug</th>
                        <th scope="col">Autor</th>
                        <th scope="col">Status</th>
                        <th scope="col" class="text-nowrap text-md-end">Aktionen</th>
                    </tr>
                </thead>
                <tbody>
                    {% for post in posts %}
                        <tr>
                            <td>{{ post.title }}</td>
                            <td><span class="badge text-bg-secondary">{{ post.slug }}</span></td>
                            <td>{{ post.author.fullName }}</td>
                            <td>
                                {% if post.published %}
                                    <span class="badge text-bg-success">Veröffentlicht</span>
                                {% else %}
                                    <span class="badge text-bg-secondary">Entwurf</span>
                                {% endif %}
                            </td>
                            <td class="text-md-end">
                                <div class="d-flex flex-wrap gap-2 justify-content-md-end">
                                    <a href="{{ path('admin_post_show', {id: post.id}) }}" class="btn btn-secondary btn-sm" aria-label="Anzeigen" title="Anzeigen"><i class="fa-solid fa-eye" aria-hidden="true"></i></a>
                                    <a href="{{ path('admin_post_edit', {id: post.id}) }}" class="btn btn-primary btn-sm" aria-label="Bearbeiten" title="Bearbeiten"><i class="fa-solid fa-pen-to-square" aria-hidden="true"></i></a>
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="5" class="text-center text-muted py-5">Keine Beiträge vorhanden.</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}
