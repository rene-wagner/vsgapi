{% extends 'admin/layout.html.twig' %}

{% block title %}Beiträge - VSG Admin{% endblock %}

{% block content %}
    <div class="main-header">
        <h1>Beiträge</h1>
        <a href="{{ path('admin_post_new') }}" class="btn btn-primary">Neuer Beitrag</a>
    </div>

    <div class="card" style="padding: 0; overflow: hidden;">
        <table>
            <thead>
                <tr>
                    <th>Titel</th>
                    <th>Slug</th>
                    <th>Autor</th>
                    <th>Status</th>
                    <th style="width: 200px;">Aktionen</th>
                </tr>
            </thead>
            <tbody>
                {% for post in posts %}
                    <tr>
                        <td>{{ post.title }}</td>
                        <td><span class="badge badge-secondary">{{ post.slug }}</span></td>
                        <td>{{ post.author.fullName }}</td>
                        <td>
                            {% if post.published %}
                                <span class="badge badge-success">Veröffentlicht</span>
                            {% else %}
                                <span class="badge badge-secondary">Entwurf</span>
                            {% endif %}
                        </td>
                        <td>
                            <div class="actions">
                                <a href="{{ path('admin_post_show', {id: post.id}) }}" class="btn btn-secondary btn-sm">Anzeigen</a>
                                <a href="{{ path('admin_post_edit', {id: post.id}) }}" class="btn btn-primary btn-sm">Bearbeiten</a>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="5" style="text-align: center; padding: 2rem; color: #999;">Keine Beiträge vorhanden.</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
{% endblock %}
