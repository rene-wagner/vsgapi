{% extends 'base.html.twig' %}

{% block title %}Login - VSG Admin{% endblock %}

{% block body %}
<div style="display: flex; justify-content: center; align-items: center; min-height: 100vh; background: #1a1a2e;">
    <div class="card" style="width: 400px;">
        <h1 style="font-size: 1.5rem; margin-bottom: 1.5rem; text-align: center;">VSG Admin Login</h1>

        {% if error %}
            <div class="alert alert-danger">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
        {% endif %}

        <form method="post">
            <div class="form-group">
                <label for="inputEmail">E-Mail</label>
                <input type="email" id="inputEmail" name="_username" value="{{ last_username }}" required autofocus autocomplete="email">
            </div>
            <div class="form-group">
                <label for="inputPassword">Passwort</label>
                <input type="password" id="inputPassword" name="_password" required autocomplete="current-password">
            </div>

            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

            <button type="submit" class="btn btn-primary" style="width: 100%; justify-content: center;">Anmelden</button>
        </form>
    </div>
</div>
{% endblock %}
